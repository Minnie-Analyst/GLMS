@model GLMS.Models.Client

@{
    ViewData["Title"] = "Edit Client";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0 p-4">

        <h2 class="mb-4 text-success">
            Edit Client
        </h2>

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="All"
                 class="text-danger mb-3">
            </div>

            <div class="mb-3">
                <label asp-for="Name"
                       class="form-label">
                    Full Name
                </label>

                <input asp-for="Name"
                       class="form-control" />

                <span asp-validation-for="Name"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="IdNumber"
                       class="form-label">
                    ID Number
                </label>

                <input asp-for="IdNumber"
                       class="form-control" />

                <span asp-validation-for="IdNumber"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="ContactDetails"
                       class="form-label">
                    Email
                </label>

                <input asp-for="ContactDetails"
                       class="form-control" />

                <span asp-validation-for="ContactDetails"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="PhoneNumber"
                       class="form-label">
                    Phone Number
                </label>

                <input asp-for="PhoneNumber"
                       class="form-control" />

                <span asp-validation-for="PhoneNumber"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="BusinessName"
                       class="form-label">
                    Business Name
                </label>

                <input asp-for="BusinessName"
                       class="form-control" />

                <span asp-validation-for="BusinessName"
                      class="text-danger">
                </span>
            </div>

            <div class="mb-3">
                <label asp-for="Region"
                       class="form-label">
                    Region
                </label>

                <input asp-for="Region"
                       class="form-control" />

                <span asp-validation-for="Region"
                      class="text-danger">
                </span>
            </div>

            <button type="submit"
                    class="btn btn-success">
                Save Changes
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Back
            </a>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}