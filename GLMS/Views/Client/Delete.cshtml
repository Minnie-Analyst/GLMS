@model GLMS.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0 p-4">

        <h2 class="text-danger mb-4">
            Delete Client
        </h2>

        <h5>
            Are you sure you want to delete this client?
        </h5>

        <hr />

        <dl class="row">

            <dt class="col-sm-3">
                Full Name
            </dt>

            <dd class="col-sm-9">
                @Model.Name
            </dd>

            <dt class="col-sm-3">
                Email
            </dt>

            <dd class="col-sm-9">
                @Model.ContactDetails
            </dd>

            <dt class="col-sm-3">
                Region
            </dt>

            <dd class="col-sm-9">
                @Model.Region
            </dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="Id" />

            <button type="submit"
                    class="btn btn-danger">
                Delete
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>

</div>