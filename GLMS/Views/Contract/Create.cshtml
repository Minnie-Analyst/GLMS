@model GLMS.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
}

<div class="container mt-4">

    <h2 class="mb-4">Create Contract</h2>

    <form asp-action="Create"
          method="post"
          enctype="multipart/form-data">

        <div asp-validation-summary="All"
             class="alert alert-danger">
        </div>

        <!-- CLIENT -->
        <div class="mb-3">

            <label class="form-label">
                Client
            </label>

            <select asp-for="ClientId"
                    class="form-select"
                    asp-items="ViewBag.ClientId">

                <option value="">
                    -- Select Client --
                </option>

            </select>

        </div>

        <!-- START DATE -->
        <div class="mb-3">

            <label class="form-label">
                Start Date
            </label>

            <input asp-for="StartDate"
                   type="date"
                   class="form-control" />

        </div>

        <!-- END DATE -->
        <div class="mb-3">

            <label class="form-label">
                End Date
            </label>

            <input asp-for="EndDate"
                   type="date"
                   class="form-control" />

        </div>

        <!-- STATUS -->
        <div class="mb-3">

            <label class="form-label">
                Status
            </label>

            <select asp-for="Status"
                    class="form-select">

                <option value="Draft">Draft</option>

                <option value="Active">Active</option>

                <option value="Expired">Expired</option>

                <option value="On Hold">On Hold</option>

            </select>

        </div>

        <!-- SERVICE LEVEL -->
        <div class="mb-3">

            <label class="form-label">
                Service Level
            </label>

            <input asp-for="ServiceLevel"
                   class="form-control" />

        </div>

        <!-- PDF -->
        <div class="mb-3">

            <label class="form-label">
                Signed Agreement PDF
            </label>

            <input type="file"
                   name="file"
                   class="form-control" />

        </div>

        <button type="submit"
                class="btn btn-success">
            Save Contract
        </button>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}