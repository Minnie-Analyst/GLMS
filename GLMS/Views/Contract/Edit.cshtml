@model GLMS.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<div class="container mt-4">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <div class="card shadow-sm border-0 p-4">

        <h2 class="fw-bold text-success mb-4">
            Edit Contract
        </h2>

        <form asp-action="Edit"
              method="post"
              enctype="multipart/form-data">

            <input type="hidden"
                   asp-for="Id" />

            <div asp-validation-summary="All"
                 class="text-danger mb-3">
            </div>

            <!-- CLIENT -->
            <div class="mb-3">

                <label class="form-label">
                    Client
                </label>

                <select asp-for="ClientId"
                        asp-items="ViewBag.ClientId"
                        class="form-select">
                </select>

            </div>

            <!-- START DATE -->
            <div class="mb-3">

                <label asp-for="StartDate"
                       class="form-label">
                    Start Date
                </label>

                <input asp-for="StartDate"
                       type="date"
                       class="form-control" />

            </div>

            <!-- END DATE -->
            <div class="mb-3">

                <label asp-for="EndDate"
                       class="form-label">
                    End Date
                </label>

                <input asp-for="EndDate"
                       type="date"
                       class="form-control" />

            </div>

            <!-- STATUS -->
            <div class="mb-3">

                <label asp-for="Status"
                       class="form-label">
                    Status
                </label>

                <select asp-for="Status"
                        class="form-select">

                    <option value="Draft">Draft</option>
                    <option value="Active">Active</option>
                    <option value="Expired">Expired</option>
                    <option value="On Hold">On Hold</option>

                </select>

            </div>

            <!-- SERVICE LEVEL -->
            <div class="mb-3">

                <label asp-for="ServiceLevel"
                       class="form-label">
                    Service Level
                </label>

                <input asp-for="ServiceLevel"
                       class="form-control" />

            </div>

            <!-- PDF -->
            <div class="mb-3">

                <label class="form-label">
                    Upload New PDF
                </label>

                <input type="file"
                       name="file"
                       class="form-control" />

            </div>

            <!-- CURRENT PDF -->
            @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <div class="mb-3">

                    <a asp-action="Download"
                       asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary">

                        Download Current PDF

                    </a>

                </div>
            }

            <!-- BUTTONS -->
            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-success">

                    Save Changes

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Back

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}