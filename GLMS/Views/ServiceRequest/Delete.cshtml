@model GLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0 p-4">

        <h2 class="fw-bold text-danger mb-4">
            Delete Service Request
        </h2>

        <div class="alert alert-warning">

            Are you sure you want to delete this service request?

        </div>

        <hr />

        <dl class="row">

            <dt class="col-sm-3">
                Contract
            </dt>

            <dd class="col-sm-9">
                Contract @Model.ContractId
            </dd>

            <dt class="col-sm-3">
                Description
            </dt>

            <dd class="col-sm-9">
                @Model.Description
            </dd>

            <dt class="col-sm-3">
                USD Cost
            </dt>

            <dd class="col-sm-9">
                $@Model.CostUSD
            </dd>

            <dt class="col-sm-3">
                ZAR Cost
            </dt>

            <dd class="col-sm-9">
                R @Model.CostZAR
            </dd>

            <dt class="col-sm-3">
                Status
            </dt>

            <dd class="col-sm-9">
                @Model.Status
            </dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="Id" />

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-danger">

                    Delete

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>