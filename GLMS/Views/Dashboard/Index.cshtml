@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<div class="container mt-4">

    <!-- HEADER -->
    <div class="mb-5">

        <h1 class="fw-bold text-success">
            GLMS Dashboard
        </h1>

        <p class="text-muted">
            Enterprise logistics analytics and operational overview
        </p>

    </div>

    <!-- STATS -->
    <div class="row g-4">

        <!-- CLIENTS -->
        <div class="col-md-4">

            <a asp-controller="Client"
               asp-action="Index"
               class="dashboard-link">

                <div class="card dashboard-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <h6 class="text-muted">
                                    Total Clients
                                </h6>

                                <h2 class="fw-bold">
                                    @ViewBag.TotalClients
                                </h2>

                            </div>

                            <div class="icon-circle bg-success-subtle text-success">
                                <i class="fas fa-users"></i>
                            </div>

                        </div>

                    </div>

                </div>

            </a>

        </div>

        <!-- CONTRACTS -->
        <div class="col-md-4">

            <a asp-controller="Contract"
               asp-action="Index"
               class="dashboard-link">

                <div class="card dashboard-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <h6 class="text-muted">
                                    Total Contracts
                                </h6>

                                <h2 class="fw-bold">
                                    @ViewBag.TotalContracts
                                </h2>

                            </div>

                            <div class="icon-circle bg-primary-subtle text-primary">
                                <i class="fas fa-file-signature"></i>
                            </div>

                        </div>

                    </div>

                </div>

            </a>

        </div>

        <!-- ACTIVE -->
        <div class="col-md-4">

            <a asp-controller="Contract"
               asp-action="Index"
               class="dashboard-link">

                <div class="card dashboard-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <h6 class="text-muted">
                                    Active Contracts
                                </h6>

                                <h2 class="fw-bold text-success">
                                    @ViewBag.ActiveContracts
                                </h2>

                            </div>

                            <div class="icon-circle bg-success-subtle text-success">
                                <i class="fas fa-check-circle"></i>
                            </div>

                        </div>

                    </div>

                </div>

            </a>

        </div>

        <!-- EXPIRED -->
        <div class="col-md-4">

            <a asp-controller="Contract"
               asp-action="Index"
               class="dashboard-link">

                <div class="card dashboard-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <h6 class="text-muted">
                                    Expired Contracts
                                </h6>

                                <h2 class="fw-bold text-danger">
                                    @ViewBag.ExpiredContracts
                                </h2>

                            </div>

                            <div class="icon-circle bg-danger-subtle text-danger">
                                <i class="fas fa-times-circle"></i>
                            </div>

                        </div>

                    </div>

                </div>

            </a>

        </div>

        <!-- REQUESTS -->
        <div class="col-md-4">

            <a asp-controller="ServiceRequest"
               asp-action="Index"
               class="dashboard-link">

                <div class="card dashboard-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <h6 class="text-muted">
                                    Service Requests
                                </h6>

                                <h2 class="fw-bold">
                                    @ViewBag.TotalRequests
                                </h2>

                            </div>

                            <div class="icon-circle bg-warning-subtle text-warning">
                                <i class="fas fa-truck"></i>
                            </div>

                        </div>

                    </div>

                </div>

            </a>

        </div>

        <!-- PENDING -->
        <div class="col-md-4">

            <a asp-controller="ServiceRequest"
               asp-action="Index"
               class="dashboard-link">

                <div class="card dashboard-card h-100">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <h6 class="text-muted">
                                    Pending Requests
                                </h6>

                                <h2 class="fw-bold text-warning">
                                    @ViewBag.PendingRequests
                                </h2>

                            </div>

                            <div class="icon-circle bg-warning-subtle text-warning">
                                <i class="fas fa-clock"></i>
                            </div>

                        </div>

                    </div>

                </div>

            </a>

        </div>

        <!-- REVENUE -->
        <div class="col-md-12">

            <div class="card revenue-card p-5 text-center">

                <div class="mb-3">

                    <div class="revenue-icon">
                        <i class="fas fa-coins"></i>
                    </div>

                </div>

                <h5 class="text-muted">
                    Total Revenue (ZAR)
                </h5>

                <h1 class="display-4 fw-bold text-success">

                    R @ViewBag.TotalRevenue

                </h1>

            </div>

        </div>

    </div>

</div>

<style>

    body {
        background-color: #f5fbf7;
    }

    .dashboard-link {
        text-decoration: none;
    }

    .dashboard-card {
        border: none;
        border-radius: 20px;
        padding: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

        .dashboard-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

    .icon-circle {
        width: 65px;
        height: 65px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .revenue-card {
        border: none;
        border-radius: 25px;
        background: linear-gradient(to right, #f6fff9, #ecfff3);
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    .revenue-icon {
        width: 90px;
        height: 90px;
        margin: auto;
        border-radius: 50%;
        background-color: #e9f8ef;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 38px;
        color: #198754;
    }

</style>